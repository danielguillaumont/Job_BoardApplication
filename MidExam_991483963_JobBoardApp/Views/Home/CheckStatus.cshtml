@model List<string>

<h2>Check Application Status</h2>

<form asp-action="Search" method="get">
    <label>Email:</label><br />
    <input type="text" name="email" value="@ViewBag.Email" />
    <button type="submit">Search</button>
</form>

<hr />

@if (Model != null && Model.Count > 0)
{
    <h3>Applications found for: @ViewBag.Email</h3>
    <ul>
        @foreach (var title in Model)
        {
            <li>@title</li>
        }
    </ul>
}
else if (!string.IsNullOrWhiteSpace(ViewBag.Email))
{
    <p><strong>No applications found for:</strong> @ViewBag.Email</p>
}

<br />
<a asp-action="Index">Back to Job Listings</a>
