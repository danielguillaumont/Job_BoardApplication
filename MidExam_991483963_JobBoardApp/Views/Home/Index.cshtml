@model List<MidExam_991483963_JobBoardApp.Models.JobPosting>

@{
    ViewData["Title"] = "Job Listings";
}

<h2>Job Listings</h2>

@if (TempData["Msg"] != null)
{
    <p style="color:green;">
        @TempData["Msg"]
    </p>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Job Title</th>
            <th>Department</th>
            <th>Closing Date</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var job in Model)
        {
            <partial name="_JobRow" model="job" />
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="CheckStatus">Check Status</a>
</div>
